      "pluginVersion": "12.0.2",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${datasource}"
          },
          "query": "// First part: without derivatives\nbaseQuery = from(bucket: \"cluster\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"cpustat\" or r[\"_measurement\"] == \"system\")\n  |> filter(fn: (r) => \n      r[\"_field\"] == \"cpus\" or \n      r[\"_field\"] == \"cpu\" or \n      r[\"_field\"] == \"status\" or \n      r[\"_field\"] == \"uptime\" or \n      r[\"_field\"] == \"maxmem\" or \n      r[\"_field\"] == \"mem\" or \n      r[\"_field\"] == \"maxdisk\" or \n      r[\"_field\"] == \"diskread\" or \n      r[\"_field\"] == \"diskwrite\" or \n      r[\"_field\"] == \"netin\" or \n      r[\"_field\"] == \"netout\"\n    )\n  |> filter(fn: (r) => r[\"object\"] == \"qemu\")  // <-- only VMs here\n\n// Derivative part\nderivativeQuery = baseQuery\n  |> filter(fn: (r) => \n      r[\"_field\"] == \"diskread\" or \n      r[\"_field\"] == \"diskwrite\" or \n      r[\"_field\"] == \"netin\" or \n      r[\"_field\"] == \"netout\"\n    )\n  |> derivative(unit: 1s, nonNegative: true)\n\n// Non-derivative part\nnonDerivativeQuery = baseQuery\n  |> filter(fn: (r) => \n      r[\"_field\"] != \"diskread\" and \n      r[\"_field\"] != \"diskwrite\" and \n      r[\"_field\"] != \"netin\" and \n      r[\"_field\"] != \"netout\"\n    )\n  |> last()\n\n// Combine queries\ncombinedQuery = union(tables: [derivativeQuery, nonDerivativeQuery])\n  |> pivot(rowKey: [\"vmid\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group(columns: [\"_measurement\"])\n\n// Add ram_usage_percent field separately\nramUsageQuery = combinedQuery\n  |> map(fn: (r) => {\n    r_mem = if exists r.mem then r.mem else 0.0\n    r_maxmem = if exists r.maxmem then r.maxmem else 1.0\n    r_usage = (float(v: r_mem) / float(v: r_maxmem)) * 100.0\n    return { r with ram_usage_percent: r_usage }\n  })\n\n// Final query with yield\nfinalQuery = ramUsageQuery\n  |> keep(columns: [\"host\", \"vmid\", \"nodename\", \"status\", \"uptime\", \"cpus\", \"cpu\", \"maxmem\", \"mem\", \"diskread\", \"diskwrite\", \"ram_usage_percent\"])\n  |> sort(columns: [\"!mem\"])\n  |> yield(name: \"result\")\n",
          "refId": "A"
        }
      ],
      "title": "VM List",
      "transparent": true,
      "type": "table"
    },
